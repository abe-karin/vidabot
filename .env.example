# OpenAI API Key (recomendado - ativação imediata; não use chaves sk-ant aqui)
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxx
# Anthropic API Key (alternativa - requer ativação de conta)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Google Gemini API Key (alternativa - acesso gratuito disponível)
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
# Provedor padrão do LLM: openai, anthropic ou gemini
LLM_PROVIDER=openai
# Modelo OpenAI opcional
OPENAI_MODEL=gpt-3.5-turbo
# Modelo Anthropic opcional (recomendado: `claude-sonnet-4-20250514` quando disponível)
# O backend tenta preferir `claude-sonnet-4-20250514` se não for especificado.
# Se o modelo preferido não estiver disponível, o sistema fará fallback
# para uma versão compatível (ex.: `claude-sonnet-4-6`) e anexará uma nota
# técnica na resposta explicando o motivo do fallback.
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# Modelo Gemini opcional
GEMINI_MODEL=models/gemini-2.5-flash-lite 
